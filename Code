<!-- ════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════ -->
<script>
// ─── DATA ───────────────────────────────
const MENU = [
  { name:"Pastel de Chocolate", price:85, emoji:"🍫", desc:"Esponjoso bizcocho de cacao con ganache de chocolate belga." },
  { name:"Cheesecake de Fresa", price:75, emoji:"🍓", desc:"Base crujiente de galleta con cremoso queso y compota de fresa." },
  { name:"Tiramisú Artesanal", price:80, emoji:"☕", desc:"Clásico italiano con mascarpone, espresso y cacao en polvo." },
  { name:"Pastel Red Velvet", price:90, emoji:"❤️", desc:"Terciopelo rojo con frosting de queso crema y vainilla." },
  { name:"Macaron Francés", price:35, emoji:"🌸", desc:"Delicadas conchas de almendra con ganache de frambuesa." },
  { name:"Fondant de Chocolate", price:70, emoji:"🍮", desc:"Coulant tierno de chocolate oscuro con corazón líquido." },
  { name:"Creme Brûlée", price:65, emoji:"🔥", desc:"Crema de vainilla francesa con costra caramelizada crujiente." },
  { name:"Cupcakes Surtidos", price:45, emoji:"🧁", desc:"Mini pasteles decorados, disponibles en varios sabores." },
];

const PROMOS = [
  { title:"Caja de 12 Macarons", badge:"⭐ Más Popular", desc:"Surtido de sabores: vainilla, frambuesa, pistache y más.", price:"Q 360", original:"Q 420", img:"🌸" },
  { title:"Pastel de Cumpleaños", badge:"🎂 Personalizado", desc:"Diseño a tu gusto con mensaje y decoración incluida.", price:"Q 250", original:"Q 300", img:"🎂" },
  { title:"Box de Postres", badge:"🎁 Box Dulce", desc:"Mix de 6 postres miniatura perfectos para compartir.", price:"Q 180", original:"Q 220", img:"🎁" },
];

// ─── STATE ──────────────────────────────
let cart = {};
let reviews = JSON.parse(localStorage.getItem('da-reviews') || '[]');
let isAdmin = false;
let currentRating = 0;
let toastTimer = null;

// Seed reviews
if (reviews.length === 0) {
  reviews = [];
}

// ─── INIT ───────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  renderMenu();
  renderPromos();
  renderReviews();
  initShareLinks();
  initScrollObserver();
  initNavbarScroll();
});

// ─── MENU ───────────────────────────────
function renderMenu() {
  const grid = document.getElementById('menu-grid');
  grid.innerHTML = MENU.map(item => `
    <div class="fade-in bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
      <div class="h-36 flex items-center justify-center text-6xl bg-gradient-to-br from-pink-50 to-amber-50">${item.emoji}</div>
      <div class="p-5">
        <h3 class="font-serif text-lg font-semibold mb-1">${item.name}</h3>
        <p class="text-gray-500 text-sm mb-4">${item.desc}</p>
        <div class="flex items-center justify-between">
          <span class="font-sans font-bold text-primary text-lg">Q ${item.price}</span>
          <div class="flex items-center gap-2">
            <button onclick="removeFromCart('${item.name}')" class="w-8 h-8 rounded-full border border-gray-200 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition-colors text-lg font-bold">−</button>
            <span id="qty-${item.name.replace(/\s/g,'-')}" class="w-6 text-center font-semibold text-sm">0</span>
            <button onclick="addToCart('${item.name}',${item.price})" class="w-8 h-8 rounded-full bg-primary text-white flex items-center justify-center hover:bg-pink-700 transition-colors text-lg font-bold">+</button>
          </div>
        </div>
      </div>
    </div>
  `).join('');
}

// ─── PROMOS ─────────────────────────────
function renderPromos() {
  const grid = document.getElementById('promo-grid');
  grid.innerHTML = PROMOS.map(p => `
    <div class="fade-in bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100">
      <div class="text-4xl mb-4">${p.img}</div>
      <span class="text-xs font-semibold bg-primary/10 text-primary rounded-full px-3 py-1">${p.badge}</span>
      <h3 class="font-serif text-xl font-semibold mt-3 mb-2">${p.title}</h3>
      <p class="text-gray-500 text-sm mb-4">${p.desc}</p>
      <div class="flex items-center gap-3 mb-5">
        <span class="font-sans font-bold text-2xl text-primary">${p.price}</span>
        <span class="font-sans text-gray-400 line-through text-sm">${p.original}</span>
      </div>
      <a href="https://wa.me/50254895074?text=${encodeURIComponent('Hola! Me interesa la promoción: ' + p.title)}" target="_blank"
        class="flex items-center justify-center gap-2 w-full bg-[#25D366] text-white rounded-xl py-2.5 font-semibold hover:bg-green-600 transition-colors text-sm">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Consultar oferta
      </a>
    </div>
  `).join('');
}

// ─── CART ───────────────────────────────
function addToCart(name, price) {
  if (!cart[name]) cart[name] = { price, qty: 0 };
  cart[name].qty++;
  updateCartUI();
  updateQtyDisplay(name);
}
function removeFromCart(name) {
  if (cart[name] && cart[name].qty > 0) {
    cart[name].qty--;
    if (cart[name].qty === 0) delete cart[name];
  }
  updateCartUI();
  updateQtyDisplay(name);
}
function updateQtyDisplay(name) {
  const el = document.getElementById('qty-' + name.replace(/\s/g, '-'));
  if (el) el.textContent = cart[name] ? cart[name].qty : 0;
}
function updateCartUI() {
  const total = Object.values(cart).reduce((s, i) => s + i.price * i.qty, 0);
  const count = Object.values(cart).reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('cart-badge');
  if (count > 0) {
    badge.classList.remove('hidden');
    badge.textContent = count;
    badge.classList.add('cart-badge');
    setTimeout(() => badge.classList.remove('cart-badge'), 200);
  } else {
    badge.classList.add('hidden');
  }
  document.getElementById('cart-total').textContent = 'Q ' + total.toFixed(2);
  const items = document.getElementById('cart-items');
  const empty = document.getElementById('cart-empty');
  const footer = document.getElementById('cart-footer');
  if (count === 0) {
    items.innerHTML = '';
    empty.classList.remove('hidden');
    footer.classList.add('hidden');
  } else {
    empty.classList.add('hidden');
    footer.classList.remove('hidden');
    items.innerHTML = Object.entries(cart).map(([name, {price, qty}]) => `
      <div class="flex items-center justify-between gap-3">
        <div class="flex-1">
          <p class="font-medium text-sm">${name}</p>
          <p class="font-sans text-primary text-sm font-semibold">Q ${(price*qty).toFixed(2)}</p>
        </div>
        <div class="flex items-center gap-2">
          <button onclick="removeFromCart('${name}')" class="w-7 h-7 rounded-full border border-gray-200 text-gray-500 flex items-center justify-center hover:bg-gray-50 font-bold">−</button>
          <span class="w-5 text-center text-sm font-semibold">${qty}</span>
          <button onclick="addToCart('${name}',${price})" class="w-7 h-7 rounded-full bg-primary text-white flex items-center justify-center hover:bg-pink-700 font-bold">+</button>
        </div>
      </div>
    `).join('<hr class="border-gray-100"/>');
  }
}
function toggleCart() {
  const el = document.getElementById('cart-overlay');
  el.classList.toggle('hidden');
  updateCartUI();
}
function orderViaWhatsApp() {
  const lines = Object.entries(cart).map(([name,{price,qty}]) => `• ${qty}x ${name} – Q${(price*qty).toFixed(2)}`).join('\n');
  const total = Object.values(cart).reduce((s,i)=>s+i.price*i.qty,0);
  const msg = `¡Hola Dolce Aroma! 🍰 Quiero hacer un pedido:\n\n${lines}\n\n*Total: Q${total.toFixed(2)}*`;
  window.open('https://wa.me/50254895074?text=' + encodeURIComponent(msg), '_blank');
}

// ─── REVIEWS ────────────────────────────
function saveReviews() { localStorage.setItem('da-reviews', JSON.stringify(reviews)); }
function renderReviews() {
  const list = document.getElementById('reviews-list');
  const empty = document.getElementById('no-reviews');
  if (reviews.length === 0) {
    list.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');
  list.innerHTML = reviews.map(r => `
    <div class="bg-cream rounded-2xl p-5 relative fade-in">
      ${isAdmin ? `<button onclick="deleteReview(${r.id})" class="absolute top-3 right-3 w-7 h-7 flex items-center justify-center rounded-full bg-red-100 text-red-500 hover:bg-red-200 transition-colors text-xs font-bold" title="Eliminar">✕</button>` : ''}
      <div class="flex items-center gap-3 mb-3">
        <div class="w-9 h-9 rounded-full bg-primary text-white flex items-center justify-center font-semibold text-sm">${r.name.charAt(0)}</div>
        <div>
          <p class="font-semibold text-sm">${r.name}</p>
          <div class="flex gap-0.5">${'★'.repeat(r.rating)}<span class="text-gray-200">${'★'.repeat(5-r.rating)}</span></div>
        </div>
      </div>
      <p class="text-gray-600 text-sm leading-relaxed">${r.comment}</p>
    </div>
  `).join('');
  // Re-apply star colors
  list.querySelectorAll('.flex.gap-0\\.5').forEach(el => {
    const filled = el.querySelectorAll('span:not(.text-gray-200)');
    filled.forEach(s => s.style.color = '#f59e0b');
  });
  // Fix star rendering
  list.querySelectorAll('.flex.gap-0\\.5').forEach(el => {
    el.innerHTML = el.innerHTML.replace(/★/g, '<span style="color:#f59e0b">★</span>');
  });
  initScrollObserver();
}
function deleteReview(id) {
  reviews = reviews.filter(r => r.id !== id);
  saveReviews();
  renderReviews();
  showToast('Reseña eliminada');
}
function setRating(v) {
  currentRating = v;
  document.querySelectorAll('.star-btn').forEach(btn => {
    const bv = parseInt(btn.dataset.v);
    btn.style.color = bv <= v ? '#f59e0b' : '#d1d5db';
  });
}
function submitReview() {
  const name = document.getElementById('review-name').value.trim();
  const comment = document.getElementById('review-comment').value.trim();
  if (!name) { showToast('Por favor ingresa tu nombre'); return; }
  if (!currentRating) { showToast('Selecciona una calificación'); return; }
  if (!comment) { showToast('Escribe un comentario'); return; }
  const id = Date.now();
  reviews.unshift({ id, name, rating: currentRating, comment });
  saveReviews();
  renderReviews();
  document.getElementById('review-name').value = '';
  document.getElementById('review-comment').value = '';
  currentRating = 0;
  setRating(0);
  showToast('¡Gracias por tu reseña!');
  document.getElementById('resenas').scrollIntoView({behavior:'smooth',block:'start'});
}

// ─── ADMIN ──────────────────────────────
function openAdminModal() {
  document.getElementById('admin-overlay').classList.remove('hidden');
  document.getElementById('admin-overlay').style.display = 'flex';
  if (isAdmin) {
    document.getElementById('admin-login-view').classList.add('hidden');
    document.getElementById('admin-logged-view').classList.remove('hidden');
  } else {
    document.getElementById('admin-login-view').classList.remove('hidden');
    document.getElementById('admin-logged-view').classList.add('hidden');
  }
}
function closeAdminModal() {
  document.getElementById('admin-overlay').style.display = 'none';
  document.getElementById('admin-overlay').classList.add('hidden');
}
function doAdminLogin() {
  const user = document.getElementById('admin-user').value;
  const pass = document.getElementById('admin-pass').value;
  if (user === 'Dolce_Aroma' && pass === 'Aroma502') {
    isAdmin = true;
    document.getElementById('admin-login-view').classList.add('hidden');
    document.getElementById('admin-logged-view').classList.remove('hidden');
    document.getElementById('admin-error').classList.add('hidden');
    renderReviews();
    showToast('Modo admin activado');
  } else {
    document.getElementById('admin-error').classList.remove('hidden');
  }
}
function doAdminLogout() {
  isAdmin = false;
  closeAdminModal();
  renderReviews();
  showToast('Sesión cerrada');
}

// ─── SHARE ──────────────────────────────
function initShareLinks() {
  const url = window.location.href;
  const text = 'Descubre Dolce Aroma Repostería Profesional, los mejores postres artesanales de Guatemala.';
  document.getElementById('share-facebook').href = 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url);
  document.getElementById('share-whatsapp').href = 'https://wa.me/?text=' + encodeURIComponent(text + ' ' + url);
}
function shareInstagram() {
  const url = window.location.href;
  const text = 'Descubre Dolce Aroma Repostería Profesional, los mejores postres artesanales de Guatemala.';
  if (navigator.share) {
    navigator.share({ title:'Dolce Aroma', text, url }).catch(()=>{});
  } else {
    const el = document.createElement('textarea');
    el.value = url; el.style.position = 'fixed'; el.style.opacity = '0';
    document.body.appendChild(el); el.focus(); el.select();
    document.execCommand('copy'); document.body.removeChild(el);
    document.getElementById('ig-label').textContent = '¡Copiado!';
    setTimeout(() => document.getElementById('ig-label').textContent = 'Instagram', 2500);
  }
}
function copyLink() {
  const url = window.location.href;
  const done = () => {
    document.getElementById('copy-label').textContent = 'Copiado';
    document.getElementById('copy-icon').innerHTML = '<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/>';
    setTimeout(() => {
      document.getElementById('copy-label').textContent = 'Enlace';
      document.getElementById('copy-icon').innerHTML = '<path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" stroke="currentColor" stroke-width="2" fill="none"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" stroke="currentColor" stroke-width="2" fill="none"/>';
    }, 2500);
  };
  if (navigator.clipboard) { navigator.clipboard.writeText(url).then(done).catch(()=>done()); }
  else {
    const el = document.createElement('textarea'); el.value = url;
    el.style.position='fixed'; el.style.opacity='0';
    document.body.appendChild(el); el.focus(); el.select();
    document.execCommand('copy'); document.body.removeChild(el); done();
  }
}

// ─── TOAST ──────────────────────────────
function showToast(msg) {
  clearTimeout(toastTimer);
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  t.classList.remove('hidden');
  toastTimer = setTimeout(() => t.classList.add('hidden'), 2500);
}

// ─── SCROLL OBSERVER ────────────────────
function initScrollObserver() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
}

// ─── NAVBAR SCROLL ──────────────────────
function initNavbarScroll() {
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('navbar');
    if (window.scrollY > 20) {
      nav.classList.add('shadow-md');
    } else {
      nav.classList.remove('shadow-md');
    }
  });
}

// Close modals on Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeAdminModal();
    document.getElementById('cart-overlay').classList.add('hidden');
  }
});
</script>
