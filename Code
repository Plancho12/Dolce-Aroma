        <label class="block text-sm font-medium text-gray-700 mb-1">Tu nombre</label>
        <input id="review-name" type="text" placeholder="María García" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 bg-white text-sm" />
      </div>
      <div class="mb-3">
        <label class="block text-sm font-medium text-gray-700 mb-1">Calificación</label>
        <div id="star-input" class="flex gap-1">
          <button onclick="setRating(1)" class="star-btn text-2xl star-empty" data-v="1">★</button>
          <button onclick="setRating(2)" class="star-btn text-2xl star-empty" data-v="2">★</button>
          <button onclick="setRating(3)" class="star-btn text-2xl star-empty" data-v="3">★</button>
          <button onclick="setRating(4)" class="star-btn text-2xl star-empty" data-v="4">★</button>
          <button onclick="setRating(5)" class="star-btn text-2xl star-empty" data-v="5">★</button>
        </div>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">Comentario</label>
        <textarea id="review-comment" rows="3" placeholder="Cuéntanos tu experiencia..." class="w-full border border-gray-200 rounded-xl px-4 py-2.5 bg-white text-sm resize-none"></textarea>
      </div>
      <button onclick="submitReview()" class="w-full bg-primary text-white rounded-xl py-2.5 font-semibold hover:bg-pink-700 transition-colors">Enviar reseña</button>
    </div>

    <!-- Lista de reseñas -->
